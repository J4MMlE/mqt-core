module {
  func.func @testMergeRxGates() {
    %q0_0 = qco.alloc : !qco.qubit
    %c_0 = arith.constant 1.000000e+00 : f64
    %q0_1 = qco.rx(%c_0) %q0_0 : !qco.qubit -> !qco.qubit
    %q0_2 = qco.rx(%c_0) %q0_1 : !qco.qubit -> !qco.qubit
    // %q0_3 = qco.rx(%c_0) %q0_2 : !qco.qubit -> !qco.qubit
    // %q0_4 = qco.ry(%c_0) %q0_3 : !qco.qubit -> !qco.qubit

    qco.sink %q0_2 : !qco.qubit

    return
  }
}
