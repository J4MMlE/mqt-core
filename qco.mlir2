module {
  func.func @testMergeRxGates() {
    %q0_0 = qco.alloc : !qco.qubit
    %c_0 = arith.constant 1.0 : f64
    %c_1 = arith.constant 2.0 : f64
    %q0_1 = qco.ry(%c_0) %q0_0 : !qco.qubit -> !qco.qubit
    %q0_2 = qco.rz(%c_0) %q0_1 : !qco.qubit -> !qco.qubit
    %q0_3 = qco.rz(%c_1) %q0_2 : !qco.qubit -> !qco.qubit
    %q0_4 = qco.ry(%c_1) %q0_3 : !qco.qubit -> !qco.qubit
    %q0_5 = qco.rz(%c_1) %q0_4 : !qco.qubit -> !qco.qubit
    %q0_6 = qco.ry(%c_1) %q0_5 : !qco.qubit -> !qco.qubit
    qco.sink %q0_6 : !qco.qubit
    return
  }
}

