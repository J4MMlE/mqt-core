+    auto inner = b.pow({targets[0], targets[1]}, 2.0,
+                       [&](mlir::ValueRange powArgs) {
+                         auto [q0, q1] = b.swap(powArgs[0], powArgs[1]);
+                         return llvm::SmallVector<mlir::Value>{q0, q1};
+                       });
+    return llvm::to_vector(inner);
+  });
+}
